<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Auto Repair Ticket System</title>
  <link rel="stylesheet" href="css/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="header-content">
      <div>
        <h1>Auto Repair Ticket System</h1>
        <p class="tagline">York County School of Technology</p>
      </div>
      <nav class="header-buttons">
        <div class="local-login-box">
          <div class="local-login-label">Local login</div>
          <div class="local-login-actions">
            <a href="/loginpage" class="btn btn-login">Login</a>
            <a href="/signup" class="btn btn-signup">Sign Up</a>
          </div>
        </div>
      </nav>
    </div>
    <h1>Auto Repair Ticket System</h1>
    <p class="tagline">York County School of Technology</p>
    <a href="/login" class="login-link">Microsoft Login</a>
  </header>

  <main class="landing">
    <h2>Select Your Role</h2>
    <div class="role-cards">
      <a href="/mechanicDis" class="role-card mechanic-card">
        <span class="role-icon">&#128295;</span>
        <h3>Mechanic</h3>
        <p>Create and edit repair tickets, complete vehicle inspections, upload videos</p>
      </a>
      <a href="/customerDis" class="role-card customer-card">
        <span class="role-icon">&#128100;</span>
        <h3>Customer</h3>
        <p>View all your repair tickets and mechanic notes, watch inspection videos</p>
      </a>
    </div>
  </main>
</body>
</html>
