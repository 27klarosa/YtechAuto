<!doctype html>
<html>
  <head>
    <meta charset="utf-8">
    <title>Reset Password - Auto Repair Ticket System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <header class="site-header">
      <div class="header-content">
        <div>
          <h1>Auto Repair Ticket System</h1>
          <p class="tagline">York County School of Technology</p>
        </div>
      </div>
    </header>

    <main class="main-content">
      <section class="section">
        <h2>Reset password for <%= email %></h2>
        <form method="POST" action="/reset-password" class="form-grid">
          <input type="hidden" name="token" value="<%= token %>">
          <div class="form-group full-width">
            <label>New password</label>
            <input type="password" name="password" required minlength="6">
          </div>

          <div class="form-group full-width">
            <label>Confirm new password</label>
            <input type="password" name="confirm" required minlength="6">
          </div>

          <div class="form-group full-width">
            <button type="submit" class="btn btn-primary">Set new password</button>
          </div>
        </form>
      </section>
    </main>
  </body>
</html>
