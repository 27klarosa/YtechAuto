<!DOCTYPE html>
<html lang="en">
<head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Login - Auto Repair Ticket System</title>
        <link rel="stylesheet" href="/css/styles.css">
    </head>
    <body>
        <header class="site-header">
            <div class="header-content">
                <div>
                    <h1>Auto Repair Ticket System</h1>
                    <p class="tagline">York County School of Technology</p>
                </div>
                <nav class="header-buttons">
                    <a href="/" class="back-link btn btn-secondary">Back</a>
                </nav>
            </div>
        </header>

        <main class="main-content">
            <section class="section">
                <h2>Login</h2>
                <form method="POST" action="/loginPage" class="form-grid">
                    <div class="form-group full-width">
                        <label for="email">Email</label>
                        <input type="email" id="email" name="email" required>
                    </div>

                    <div class="form-group full-width">
                        <label for="password">Password</label>
                        <input type="password" id="password" name="password" required>
                    </div>

                    <div class="form-group full-width">
                        <button type="submit" class="btn btn-primary">Login</button>
                    </div>
                </form>

                <hr>

                <div class="section">
                    <h3>Forgot password?</h3>
                    <form method="POST" action="/request-reset" class="form-grid">
                        <div class="form-group full-width">
                            <label for="resetEmail">Email</label>
                            <input type="email" id="resetEmail" name="email" required>
                        </div>
                        <div class="form-group full-width">
                            <button type="submit" class="btn btn-secondary">Send reset link</button>
                        </div>
                    </form>
                </div>
            </section>
        </main>
    </body>
</html>