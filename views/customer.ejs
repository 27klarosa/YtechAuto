<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Customer - Auto Repair Ticket System</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="site-header">
    <a href="/">Auto Repair Ticket System</a>
    <p class="tagline">Customer View - Your Repair Ticket</p>
  </header>

  <main class="main-content">
    <a href="/" class="back-link">&larr; Back to Home</a>
    <a href="/customerDis" class="btn btn-secondary" style="margin-left:1rem">View All</a>
    
    <% if (typeof ticket !== 'undefined') { %>
      <!-- Ticket Summary -->
      <section class="section">
        <h2>Repair Ticket #<%= ticket.id %></h2>
        <div class="form-grid">
          <div class="read-only-value">
            <div class="read-only-label">Date</div>
            <div><%= ticket.date %></div>
          </div>
          <div class="read-only-value">
            <div class="read-only-label">Technician</div>
            <div><%= ticket.techName %></div>
          </div>
          <div class="read-only-value">
            <div class="read-only-label">Vehicle</div>
            <div><%= vehicle.yearV || '' %> <%= vehicle.make || '' %> <%= vehicle.model || '' %></div>
          </div>
          <div class="read-only-value">
            <div class="read-only-label">License Plate</div>
            <div><%= vehicle.plate || 'N/A' %></div>
          </div>
          <div class="read-only-value">
            <div class="read-only-label">Mileage In / Out</div>
            <div><%= vehicle.mileageO || 'N/A' %> / <%= vehicle.mileageC || 'N/A' %></div>
          </div>
        </div>
      </section>

      <!-- Mechanic Notes - Concern -->
      <section class="section">
        <h2>Your Concern</h2>
        <p><%= ticket.concern %></p>
      </section>

      <!-- Mechanic Notes - Diagnosis -->
      <section class="section">
        <h2>Diagnosis / Cause / Correction</h2>
        <p><%= ticket.diagnosis %></p>
      </section>

      <!-- Work Performed -->
      <section class="section">
        <h2>Work Performed</h2>
        <% if (repairs && repairs.length > 0) { %>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Description of Work</th>
                  <th>Qty</th>
                  <th>Parts #</th>
                  <th>Parts Total $</th>
                  <th>Labour Total $</th>
                </tr>
              </thead>
              <tbody>
                <% repairs.forEach(repair => { %>
                  <tr>
                    <td><%= repair.repairDescription %></td>
                    <td><%= repair.qty %></td>
                    <td><%= repair.partNumber %></td>
                    <td>$<%= parseFloat(repair.partsTotal || 0).toFixed(2) %></td>
                    <td>$<%= parseFloat(repair.laborTotal || 0).toFixed(2) %></td>
                  </tr>
                <% }) %>
                <!-- Fill empty rows if less than 4 repairs -->
                <% for (let i = repairs.length; i < 4; i++) { %>
                  <tr>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                    <td></td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
          
          <div class="form-grid" style="margin-top:1rem; max-width:400px">
            <div class="read-only-value">
              <div class="read-only-label">Subtotal (Parts)</div>
              <div>$<%= totals.partsSubtotal %></div>
            </div>
            <div class="read-only-value">
              <div class="read-only-label">Subtotal (Labour)</div>
              <div>$<%= totals.laborSubtotal %></div>
            </div>
            <div class="read-only-value">
              <div class="read-only-label">Tax</div>
              <div>$<%= totals.tax %></div>
            </div>
            <div class="read-only-value">
              <div class="read-only-label">Total(Barring labour)</div>
              <div><strong>$<%= totals.total %></strong></div>
            </div>
          </div>
        <% } else { %>
          <p>No repair details available for this ticket.</p>
        <% } %>
      </section>

      <!-- Vehicle Inspection Summary -->
      <section class="section">
        <h2>Vehicle Inspection Summary</h2>
        <p>Warnings from courtesy check:</p>
        <div class="inspection-summary">
          <div class="inspection-item">
            <span class="status-badge status-yellow">Monitor</span>
            <span>Items to watch</span>
          </div>
          <div id="monitorItems">
            <% if (inspection && inspection.monitorItems && inspection.monitorItems.length) { %>
              <ul class="inspection-list">
                <% inspection.monitorItems.forEach(item => { %>
                  <li><span class="status-badge status-yellow">Monitor</span> <%= item %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
          <div class="inspection-item">
            <span class="status-badge status-red">Needs Service</span>
            <span>Items requiring attention</span>
          </div>
          <div id="badItems">
            <% if (inspection && inspection.badItems && inspection.badItems.length) { %>
              <ul class="inspection-list">
                <% inspection.badItems.forEach(item => { %>
                  <li><span class="status-badge status-red">Needs Service</span> <%= item %></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        </div>
      </section>

      <!-- Video Section -->
      <section class="section video-section">
        <h2>Inspection Video</h2>
        <p>Watch the mechanic's video walkthrough of the inspection and repairs.</p>
        <% if (typeof video !== 'undefined' && video && video.webPath) { %>
          <video controls width="640">
            <source src="<%= video.webPath %>" type="<%= video.mimeType || 'video/webm' %>">
            Your browser does not support the video tag.
          </video>
          <div>
            <a href="<%= video.webPath %>" download="<%= video.originalName || 'inspection-video' %>" class="video-download-link">Download Video</a>
          </div>
        <% } else { %>
          <video controls width="640">
            <source src="Recording-20260212_111802.webm" type="video/webm">
            Your browser does not support the video tag.
          </video>
          <div>
            <a href="Recording-20260212_111802.webm" download="inspection-video.webm" class="video-download-link">Download Video</a>
          </div>  
        <% } %>
      </section>

      <!-- Image Section -->
      <section class="section image-section">
        <h2>Inspection Images</h2>
        <p>Review the images taken during the inspection.</p>
        <% /* Prefer the images array (passed from route). Fall back to single image for backward compatibility */ %>
        <% const imgsToRender = (typeof images !== 'undefined' && Array.isArray(images)) ? images : ((typeof image !== 'undefined' && image) ? [image] : []); %>
        <% if (imgsToRender && imgsToRender.length) { %>
          <div class="image-gallery" style="display:flex;flex-wrap:wrap;gap:12px;margin-top:12px;">
            <% imgsToRender.forEach((it, i) => { 
                 const src = (typeof it === 'string') ? it : (it.webPath || it.src || it.url || it.path || '');
                 const name = (typeof it === 'object' && (it.originalName || it.filename || it.name)) ? (it.originalName || it.filename || it.name) : (`image-${i}`);
            %>
              <figure style="width:200px;margin:0;">
                <img src="<%= src %>" alt="<%= name %>" class="inspection-image" data-name="<%= name %>" data-src="<%= src %>" style="width:100%;height:auto;border:1px solid #ddd;border-radius:4px;display:block;">
                <figcaption style="font-size:12px;margin-top:6px;display:flex;justify-content:space-between;align-items:center;">
                  <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:120px;"><%= name %></span>
                  <a href="<%= src %>" download="<%= name %>" class="image-download-link" style="font-size:12px;">Download</a>
                </figcaption>
              </figure>
            <% }) %>
          </div>
        <% } else { %>
          <p>No inspection images available.</p>
        <% } %>
      </section>

      <!-- Inject server payload and quick inline diagnostic logs for troubleshooting -->
      <script>
        try {
          // inject raw so client loaders can use it
          window.__SERVER_TICKET__ = <%- JSON.stringify(ticket || null) %>;
          console.log('customer.ejs: injected window.__SERVER_TICKET__', window.__SERVER_TICKET__);
          window.__IMAGES_VAR__ = <%- JSON.stringify(images || []) %>;
          console.log('customer.ejs: images array passed to template', window.__IMAGES_VAR__);
          // quick inline marker to ensure this inline script runs
          console.log('customer.ejs: inline diagnostic script executed');
        } catch (e) { console.warn('customer.ejs: diagnostic injection failed', e); }
      </script>

      <div >
            <a id="downloadPage" href="#" data-ticket-id="<%= ticket && ticket.id ? ticket.id : '' %>">Download Page As PDF</a>
           </div>
     <% } else { %>
      <section class="section">
        <h2>Ticket Not Found</h2>
        <p>The requested ticket could not be found or you don't have permission to view it.</p>
        <a href="/customerDis" class="btn btn-primary">Back to Ticket List</a>
      </section>
    <% } %>
  </main>
<script src="/js/form.js"></script>
</body>
</html>
